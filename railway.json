{
  "version": 1,
  "services": {
    "backend": {
      "source": "backend",
      "builder": "NIXPACKS",
      "buildCommand": "pip install -r requirements.txt",
      "startCommand": "python3 main.py"
    },
    "frontend": {
      "source": "frontend",
      "builder": "NIXPACKS",
      "buildCommand": "npm ci --no-audit --no-fund && npm run build",
      "startCommand": "npx next start -p $PORT",
      "variables": {
        "NODE_VERSION": "20"
      }
    }
  }
}